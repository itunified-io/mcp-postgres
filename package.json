{
  "name": "@itunified.io/mcp-postgres",
  "version": "2026.3.23-2",
  "description": "PostgreSQL MCP Server — 27 tools for schema introspection, queries, CRUD, and server management via Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-postgres": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test && node scripts/prepublish-check.js"
  },
  "keywords": ["mcp", "postgres", "postgresql", "database", "dba", "monitoring", "model-context-protocol"],
  "author": "itunified.io",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/itunified-io/mcp-postgres.git"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

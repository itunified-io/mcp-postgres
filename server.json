  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@itunified.io/mcp-postgres",
      "version": "2026.4.10-1",
      "runtimeHint": "npx",
      "runtimeArguments": [],
      "packageArguments": [],
      "environmentVariables": [
        {
          "name": "POSTGRES_CONNECTION_STRING",
